{#
/**
 * @file
 * Chip — pill tag/label.
 */
#}
{%- set tag = tag|default('span') -%}
{%- set variant = variant|default('default') -%}
{%- set _attrs = attributes|default(create_attribute()).addClass('chip') -%}
{%- if variant == 'accent' -%}{%- set _attrs = _attrs.addClass('chip--accent') -%}{%- endif -%}
{%- if tag == 'a' and href -%}{%- set _attrs = _attrs.setAttribute('href', href) -%}{%- endif -%}
<{{ tag }}{{ _attrs }}>{{ label }}</{{ tag }}>
