{#
/**
 * @file
 * Button — pill button (primary/ghost) with optional arrow.
 */
#}
{%- set tag = tag|default('a') -%}
{%- set variant = variant|default('primary') -%}
{%- set size = size|default('default') -%}
{%- set classes = [
  'btn',
  'btn--' ~ variant,
  size == 'sm' ? 'btn--sm' : '',
  arrow ? 'btn--arrow' : '',
] -%}
<{{ tag }}
  class="{{ classes|filter(c => c)|join(' ') }}"
  {%- if tag == 'a' %} href="{{ href|default('#') }}"{% endif -%}
>
  {{ label }}
  {%- if arrow %}<span class="btn__arrow" aria-hidden="true">→</span>{% endif -%}
</{{ tag }}>
