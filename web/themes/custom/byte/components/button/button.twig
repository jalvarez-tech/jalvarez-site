{#
/**
 * @file
 * Button — pill button (primary/ghost) with optional arrow.
 */
#}
{%- set tag = tag|default('a') -%}
{%- set variant = variant|default('primary') -%}
{%- set size = size|default('default') -%}
{%- set _classes = ['btn', 'btn--' ~ variant] -%}
{%- if size == 'sm' -%}{%- set _classes = _classes|merge(['btn--sm']) -%}{%- endif -%}
{%- if arrow -%}{%- set _classes = _classes|merge(['btn--arrow']) -%}{%- endif -%}
{%- set _attrs = attributes|default(create_attribute()).addClass(_classes) -%}
{%- if tag == 'a' -%}{%- set _attrs = _attrs.setAttribute('href', href|default('#')) -%}{%- endif -%}
{# External http(s) hrefs (e.g. wa.me) open in a new tab. mailto/tel use
   the user's default handler and stay in the same browsing context. #}
{%- if tag == 'a' and href and (href starts with 'http' or href starts with '//') -%}
  {%- set _attrs = _attrs.setAttribute('target', '_blank').setAttribute('rel', 'noopener') -%}
{%- endif -%}
<{{ tag }}{{ _attrs }}>
  {{ label }}
  {%- if arrow %}<span class="btn__arrow" aria-hidden="true">→</span>{% endif -%}
</{{ tag }}>
