{# Palabras de cliente — section wrapper + testimonials slot. #}
{%- set _attrs = attributes|default(create_attribute()).addClass(['section', 'wrap']) -%}
<section{{ _attrs }}>
  <div class="section__head">
    <div>
      {%- if eyebrow_label -%}
        {%- include 'byte:eyebrow' with { label: eyebrow_label, number: eyebrow_number|default(null) } only -%}
      {%- endif -%}
    </div>
    <div>
      {%- if title %}<h2 class="section__title">{{ title }}</h2>{% endif -%}
    </div>
  </div>
  <div class="tests">
    {% block testimonials %}{{ testimonials }}{% endblock %}
  </div>
</section>
