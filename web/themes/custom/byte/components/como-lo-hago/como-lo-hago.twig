{#
/**
 * @file
 * Como lo hago — section header + values slot (cards inserted by editor or
 * controller via the `values` slot).
 */
#}
<section class="section wrap" id="value">
  <div class="section__head">
    <div>
      {%- if eyebrow_label -%}
        {%- include 'byte:eyebrow' with { label: eyebrow_label, number: eyebrow_number|default(null) } only -%}
      {%- endif -%}
    </div>
    <div>
      {%- if title -%}
        <h2 class="section__title">{{ title }}{% if title_em %}<em>{{ title_em }}</em>{% endif %}</h2>
      {%- endif -%}
    </div>
  </div>

  <div class="values">
    {% block values %}{{ values }}{% endblock %}
  </div>
</section>
