{#
/**
 * @file
 * Eyebrow — § 0N · texto-mono editorial section header.
 */
#}
{%- set _attrs = attributes|default(create_attribute()).addClass('eyebrow') -%}
<div{{ _attrs }}>
  {%- if number is defined and number is not null -%}
    <span class="eyebrow__num">§ {{ number < 10 ? '0' ~ number : number }}</span>
  {%- endif -%}
  <span>{{ label }}</span>
</div>
