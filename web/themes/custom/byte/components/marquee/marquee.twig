{# Marquee — looping stack badges #}
{%- set list = items|default([]) -%}
{%- if list|length > 0 -%}
<div class="marquee">
  <div class="marquee__track">
    <span>
    {% for it in list|merge(list) %}
      <span>{{ it }}</span>
      {% if not loop.last %}<span class="marquee__dot">·</span>{% endif %}
    {% endfor %}
    </span>
  </div>
</div>
{%- endif -%}
