{# Nav glass — fixed top liquid-glass nav with mobile drawer + theme toggle #}
{%- set lang = current_lang|default('es') -%}
{%- set i18n = lang == 'en' ? {
  open_menu: 'Open menu',
  close_menu: 'Close menu',
  toggle_theme: 'Toggle theme',
  language: 'Language',
  current_page: 'Current page',
  current_lang: 'Current language',
} : {
  open_menu: 'Abrir menú',
  close_menu: 'Cerrar menú',
  toggle_theme: 'Cambiar tema',
  language: 'Idioma',
  current_page: 'Página actual',
  current_lang: 'Idioma actual',
} -%}
<header class="nav" data-nav-root>
  <div class="nav__inner">
    <a class="brand" href="/{{ lang }}">
      <span class="brand__mark">{{ brand_initial|default('J') }}</span>
      <span class="brand__name">{{ brand_name|default('jalvarez') }}<span class="brand__tld">{{ brand_tld|default('.tech') }}</span></span>
    </a>

    {%- if links|length > 0 -%}
      <nav class="nav__links nav__links--desktop" aria-label="{{ lang == 'en' ? 'Primary' : 'Principal' }}">
        {%- for l in links -%}
          <a href="{{ l.href }}" class="nav__link{{ l.active ? ' nav__link--active' : '' }}"{{ l.active ? ' aria-current="page"' : '' }}>
            {{ l.label }}
          </a>
        {%- endfor -%}

        {# When cta_href is external (e.g. wa.me WhatsApp link) open in a
           new tab. For internal aliases keep same-tab navigation. #}
        {%- set _cta_external = cta_href and (cta_href starts with 'http' or cta_href starts with '//') -%}
        <a href="{{ cta_href|default('/contacto') }}"
           class="nav__cta"
           {%- if _cta_external %} target="_blank" rel="noopener"{% endif -%}>
          <span class="status-dot" aria-hidden="true"></span>
          {{ cta_label|default('Disponible') }}
        </a>

        <button class="theme-toggle" type="button" aria-label="{{ i18n.toggle_theme }}" data-theme-toggle>
          <svg class="theme-toggle__icon theme-toggle__icon--sun" width="16" height="16" aria-hidden="true" focusable="false">
            <use href="/{{ active_theme_path() }}/icons.svg#i-sun"></use>
          </svg>
          <svg class="theme-toggle__icon theme-toggle__icon--moon" width="16" height="16" aria-hidden="true" focusable="false">
            <use href="/{{ active_theme_path() }}/icons.svg#i-moon"></use>
          </svg>
        </button>

        {%- if show_lang_toggle|default(true) -%}
          <div class="lang-toggle" role="group" aria-label="{{ i18n.language }}">
            <a href="{{ lang_es_href|default('/es') }}" class="lang-toggle__btn{{ lang == 'es' ? ' is-on' : '' }}"{{ lang == 'es' ? ' aria-current="true" lang="es" hreflang="es"' : ' lang="es" hreflang="es"' }}>ES</a>
            <a href="{{ lang_en_href|default('/en') }}" class="lang-toggle__btn{{ lang == 'en' ? ' is-on' : '' }}"{{ lang == 'en' ? ' aria-current="true" lang="en" hreflang="en"' : ' lang="en" hreflang="en"' }}>EN</a>
          </div>
        {%- endif -%}
      </nav>
    {%- endif -%}

    {# Mobile hamburger — aria-label updated by JS via data-label-* attrs #}
    <button class="nav__burger"
            type="button"
            aria-label="{{ i18n.open_menu }}"
            aria-expanded="false"
            aria-controls="nav-drawer"
            data-label-open="{{ i18n.open_menu }}"
            data-label-close="{{ i18n.close_menu }}"
            data-nav-toggle>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>
</header>

{# Mobile drawer — `inert` prevents tab focus from reaching it while hidden. #}
<div id="nav-drawer" class="nav-drawer" data-nav-drawer aria-hidden="true" inert>
  <nav class="nav-drawer__links" aria-label="{{ lang == 'en' ? 'Primary' : 'Principal' }}">
    {%- for l in links -%}
      <a href="{{ l.href }}" class="nav-drawer__link{{ l.active ? ' nav-drawer__link--active' : '' }}"{{ l.active ? ' aria-current="page"' : '' }}>
        <span class="nav-drawer__num" aria-hidden="true">{{ '%02d'|format(loop.index) }}</span>
        <span class="nav-drawer__label">{{ l.label }}</span>
        <span class="nav-drawer__arrow" aria-hidden="true">→</span>
      </a>
    {%- endfor -%}
  </nav>
  <div class="nav-drawer__foot">
    <a href="{{ cta_href|default('/contacto') }}" class="nav__cta">
      <span class="status-dot" aria-hidden="true"></span>
      {{ cta_label|default('Disponible') }}
    </a>
    <div class="lang-toggle" role="group" aria-label="{{ i18n.language }}">
      <a href="{{ lang_es_href|default('/es') }}" class="lang-toggle__btn{{ lang == 'es' ? ' is-on' : '' }}"{{ lang == 'es' ? ' aria-current="true" lang="es" hreflang="es"' : ' lang="es" hreflang="es"' }}>ES</a>
      <a href="{{ lang_en_href|default('/en') }}" class="lang-toggle__btn{{ lang == 'en' ? ' is-on' : '' }}"{{ lang == 'en' ? ' aria-current="true" lang="en" hreflang="en"' : ' lang="en" hreflang="en"' }}>EN</a>
    </div>
  </div>
</div>
