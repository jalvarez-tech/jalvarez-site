{# Método — section header + steps slot. #}
{%- set _attrs = attributes|default(create_attribute()).addClass(['section', 'wrap']).setAttribute('id', 'process') -%}
<section{{ _attrs }}>
  <div class="section__head">
    <div>
      {%- if eyebrow_label -%}
        {%- include 'byte:eyebrow' with { label: eyebrow_label, number: eyebrow_number|default(null) } only -%}
      {%- endif -%}
    </div>
    <div>
      {%- if title -%}
        <h2 class="section__title">{{ title }}{% if title_em %}<em>{{ title_em }}</em>{% endif %}</h2>
      {%- endif -%}
    </div>
  </div>

  <div class="process-list">
    {% block steps %}{{ steps }}{% endblock %}
  </div>
</section>
