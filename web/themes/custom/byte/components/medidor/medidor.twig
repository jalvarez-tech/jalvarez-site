{# Medidor — metric card #}
{%- set v = variant|default('flat') -%}
<div class="medidor medidor--{{ v }}">
  <div class="medidor__value">
    {{ value }}{% if unit %}<span class="medidor__unit">{{ unit }}</span>{% endif %}
  </div>
  {%- if key %}<div class="medidor__key">{{ key }}</div>{% endif -%}
  {%- if note %}<div class="medidor__note">{{ note }}</div>{% endif -%}
</div>
