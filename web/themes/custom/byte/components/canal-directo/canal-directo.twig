{# Canal directo — sidebar for contact page (Canvas-editable). #}
{%- set _channels = [
  { name: c1_name, value: c1_value, href: c1_href },
  { name: c2_name, value: c2_value, href: c2_href },
  { name: c3_name, value: c3_value, href: c3_href },
]|filter(c => c.name or c.value) -%}
{%- set _steps = [step_1, step_2, step_3, step_4, step_5]|filter(s => s) -%}

<aside class="contact-side">
  {%- if _channels|length > 0 -%}
    <div class="contact-card">
      <h2 class="contact-card__title">{{ channels_label|default('Canales directos') }}</h2>
      <div class="contact-channels">
        {%- for c in _channels -%}
          <div class="channel">
            <span class="channel__name">{{ c.name }}</span>
            {%- if c.href -%}
              <a class="channel__val" href="{{ c.href }}">{{ c.value }}</a>
            {%- else -%}
              <span class="channel__val">{{ c.value }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div class="contact-card">
    <h2 class="contact-card__title">{{ availability_label|default('Disponibilidad') }}</h2>
    <div class="availability">
      <span class="status-dot"></span>
      <span><strong>{{ free_value|default('2') }}</strong> {{ free_label|default('cupos libres') }}</span>
    </div>
    <div class="channel" style="margin-top: 16px;">
      <span class="channel__name">{{ response_label|default('Tiempo de respuesta') }}</span>
      <span class="channel__val">{{ response_value|default('< 24h lun-vie') }}</span>
    </div>
  </div>

  {%- if _steps|length > 0 -%}
    <div class="contact-card">
      <h2 class="contact-card__title">{{ expect_label|default('Cómo va a ser') }}</h2>
      <ol class="contact-steps">
        {%- for s in _steps -%}
          <li>{{ s }}</li>
        {%- endfor -%}
      </ol>
    </div>
  {%- endif -%}
</aside>
