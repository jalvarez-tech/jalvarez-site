{# Case step card — numbered step inside §02 Enfoque #}
<article class="case-step">
  {%- if number is defined and number is not null -%}
    <div class="case-step__num">{{ number < 10 ? '0' ~ number : number }}</div>
  {%- endif -%}
  <div class="case-step__main">
    {%- if tag %}<div class="case-step__tag">{{ tag }}</div>{% endif -%}
    {%- if title %}<h3 class="case-step__title">{{ title }}</h3>{% endif -%}
    {%- if body %}<p class="case-step__body">{{ body }}</p>{% endif -%}
  </div>
</article>
