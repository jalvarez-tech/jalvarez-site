{# Card Testimonio #}
{%- set _attrs = attributes|default(create_attribute()).addClass('test') -%}
<div{{ _attrs }}>
  <p class="test__quote">{{ quote }}</p>
  <div class="test__attr">
    {%- if initials %}<div class="test__avatar">{{ initials }}</div>{% endif -%}
    <div>
      {%- if name %}<div class="test__name">{{ name }}</div>{% endif -%}
      {%- if role %}<div class="test__role">{{ role }}</div>{% endif -%}
    </div>
  </div>
</div>
