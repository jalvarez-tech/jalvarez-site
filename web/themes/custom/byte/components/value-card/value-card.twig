{# Value card — single value tile inside Como lo hago. #}
{%- set _attrs = attributes|default(create_attribute()).addClass('value') -%}
<div{{ _attrs }}>
  <div class="value__num">
    <span>{{ '%02d'|format(number|default(1)) }}</span>
    {%- if tag %}<span class="value__tag">/ {{ tag }}</span>{% endif -%}
  </div>
  {%- if icon -%}
    <div class="value__icon">
      {% include 'byte:icon' with { name: icon, size: 32 } only %}
    </div>
  {%- endif -%}
  {%- if title %}<h3 class="value__title">{{ title }}</h3>{% endif -%}
  {%- if body %}<p class="value__body">{{ body }}</p>{% endif -%}
  {%- if metric_value -%}
    <div class="value__metric">
      {{ metric_value }}{% if metric_unit %}<span class="value__metric-unit">{{ metric_unit }}</span>{% endif %}
      {%- if caption %}<span class="value__metric-caption">{{ caption }}</span>{% endif -%}
    </div>
  {%- endif -%}
</div>
