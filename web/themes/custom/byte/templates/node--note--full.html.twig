{#
/**
 * @file
 * Note (article) detail template — Medium-style editorial.
 */
#}
{% set lang = node.get('langcode').value|default('es') %}

{# Per-language path segments aren't strings to translate via locale —
   they're the canonical aliases configured on the node bundle.
   Everything else goes through |trans so the strings land in the
   .po extraction pipeline. #}
{% set back_path = lang == 'en' ? '/notes' : '/notas' %}

{# Read time estimate #}
{% set body_text = node.body.value|default('')|striptags %}
{% set words = body_text|split(' ')|length %}
{% set read_min = max(1, (words / 200)|round(0, 'ceil')) %}

{# Format date — Drupal's |format_date doesn't expose abbreviated months
   on the default formats, so we still build the abbreviation locally. #}
{% set raw_date = node.field_publish_date.value %}
{% set date_str = '' %}
{% if raw_date %}
  {% set parts = raw_date|split('-') %}
  {% if parts|length >= 3 %}
    {% set m = (parts[1]|number_format) - 1 %}
    {% set months = lang == 'en'
      ? ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
      : ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'] %}
    {% set date_str = months[m] ~ ' ' ~ parts[2] ~ ', ' ~ parts[0] %}
  {% endif %}
{% endif %}

<article class="article">
  <div class="article__wrap">
    <a class="article__back" href="/{{ lang }}{{ back_path }}">{{ '← Back to writing'|trans({}, {'context': 'jalvarez_site'}) }}</a>

    <header class="article__head">
      <div class="article__tags">
        {% if node.field_note_topic.entity %}
          <span class="article__cat">{{ node.field_note_topic.entity.label }}</span>
          <span class="article__meta-dot">·</span>
        {% endif %}
        {% if date_str %}
          <span class="article__meta-item">{{ date_str }}</span>
          <span class="article__meta-dot">·</span>
        {% endif %}
        <span class="article__meta-item">{{ read_min }} min</span>
      </div>

      <h1 class="article__title">{{ node.label }}</h1>

      {% if not node.field_excerpi18n.isEmpty %}
        <p class="article__sub">{{ node.field_excerpi18n.value }}</p>
      {% endif %}

      <div class="article__byline">
        <div class="article__author">
          <div class="article__avatar">JA</div>
          <div>
            <div class="article__author-name">John Stevans Alvarez</div>
            <div class="article__author-role">{{ 'Senior Web Specialist · jalvarez.tech'|trans({}, {'context': 'jalvarez_site'}) }}</div>
          </div>
        </div>
        <div class="article__actions">
          <button class="article__action" aria-label="{{ 'Share'|trans({}, {'context': 'jalvarez_site'}) }}" type="button">
            {% include 'byte:icon' with { name: 'share-2' } only %}
          </button>
          <button class="article__action" aria-label="{{ 'Save'|trans({}, {'context': 'jalvarez_site'}) }}" type="button">
            {% include 'byte:icon' with { name: 'bookmark' } only %}
          </button>
          <button class="article__action" aria-label="{{ 'Copy link'|trans({}, {'context': 'jalvarez_site'}) }}" type="button">
            {% include 'byte:icon' with { name: 'copy' } only %}
          </button>
        </div>
      </div>
    </header>

    {% if not node.field_featured_media.isEmpty %}
      <div class="article__hero">
        {{ node.field_featured_media.entity ? node.field_featured_media.0 : 'IMAGEN DESTACADA' }}
      </div>
    {% else %}
      <div class="article__hero">{% if node.field_thumb_glyph.value %}
        {% include 'byte:icon' with {
          name: node.field_thumb_glyph.value,
          size: 80,
          decorative_class: 'article__hero-glyph',
        } only %}
      {% endif %}</div>
    {% endif %}

    <div class="article__body">
      {# Use the filter-format-processed value; |raw bypasses Drupal's XSS filtering. #}
      {{ node.body.processed }}
    </div>
  </div>
</article>
