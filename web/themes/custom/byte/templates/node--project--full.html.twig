{#
/**
 * @file
 * Project detail (case study) template — DESIGN.md §4.5.
 *
 * Composes:
 *   case-back link → /proyectos
 *   case-tags (chips for primary tech, year, role)
 *   case-title + case-brief
 *   case-meta (key/value: Cliente · Año · Rol · Duración · Stack · Live ↗)
 *   case-hero (placeholder for now)
 *   §01 Desafío (intro + bullets)
 *   §02 Enfoque (loop case_step paragraphs)
 *   §03 Resultados (loop metric paragraphs + embedded testimonial)
 *   §04 Aprendizaje
 *   related_projects view
 *   cta-final
 */
#}
{% set lang = node.get('langcode').value|default('es') %}

{# Per-page WhatsApp deep link: open the chat pre-filled with a message
   that names the case study the visitor was just reading, so the lead
   arrives with context ("vi el caso X") instead of a generic ping. The
   message text is kept here (not in the cta-final config) because it
   needs the project's label, which is only known at render time. #}
{%- set _wa_phone = '573128014078' -%}
{%- set _wa_msg = lang == 'en'
  ? 'Hi John, I saw the «' ~ node.label ~ '» case study on jalvarez.tech and I\'d like something similar for my project.'
  : 'Hola John, vi el caso «' ~ node.label ~ '» en jalvarez.tech y quiero algo similar para mi proyecto.'
-%}
{%- set _wa_href = 'https://wa.me/' ~ _wa_phone ~ '?text=' ~ _wa_msg|url_encode -%}

{% set i18n = lang == 'en' ? {
  back: '← Back to projects',
  back_path: '/projects',
  rol: 'Role',
  year: 'Year',
  duration: 'Duration',
  stack: 'Stack',
  live: 'Live',
  visit: 'Visit ↗',
  s1: '§ 01 Challenge',
  s2: '§ 02 Approach',
  s2_title: 'How I tackled it',
  s3: '§ 03 Results',
  s3_title: 'What happened next',
  s4: '§ 04 Lesson',
  cta_primary: 'Start your project',
  cta_primary_href: _wa_href,
  cta_secondary: 'See more projects',
  cta_secondary_path: '/projects',
} : {
  back: '← Volver a proyectos',
  back_path: '/proyectos',
  rol: 'Rol',
  year: 'Año',
  duration: 'Duración',
  stack: 'Stack',
  live: 'Live',
  visit: 'Visitar ↗',
  s1: '§ 01 Desafío',
  s2: '§ 02 Enfoque',
  s2_title: 'Cómo lo abordé',
  s3: '§ 03 Resultados',
  s3_title: 'Lo que pasó después',
  s4: '§ 04 Aprendizaje',
  cta_primary: 'Iniciar tu proyecto',
  cta_primary_href: _wa_href,
  cta_secondary: 'Ver más proyectos',
  cta_secondary_path: '/proyectos',
} %}

<article class="case wrap">
  <a class="case-back" href="/{{ lang }}{{ i18n.back_path }}">{{ i18n.back }}</a>

  {%- set _cover_url = '' -%}
  {%- set _cover_alt = '' -%}
  {%- if node.field_cover_media.entity and node.field_cover_media.entity.field_media_image.entity -%}
    {%- set _cover_file = node.field_cover_media.entity.field_media_image.entity -%}
    {%- set _cover_url = file_url(_cover_file.uri.value) -%}
    {%- set _cover_alt = node.field_cover_media.entity.field_media_image.alt|default(node.label) -%}
  {%- endif -%}

  <header class="case-head{{ _cover_url ? ' case-head--with-cover' : '' }}">
    <div class="case-head__main">
      <div class="case-tags">
        {% if node.field_primary_technology.entity %}
          {% include 'byte:chip' with { label: node.field_primary_technology.entity.label, variant: 'accent' } only %}
        {% endif %}
        {% if not node.field_project_year.isEmpty %}
          {% include 'byte:chip' with { label: node.field_project_year.value } only %}
        {% endif %}
        {% if not node.field_role.isEmpty %}
          {% include 'byte:chip' with { label: node.field_role.value } only %}
        {% endif %}
      </div>

      <h1 class="case-title">{{ node.label }}</h1>

      {% if not node.field_intro.isEmpty %}
        <p class="case-brief">{{ node.field_intro.value }}</p>
      {% elseif not node.field_summary.isEmpty %}
        <p class="case-brief">{{ node.field_summary.value }}</p>
      {% endif %}

      <dl class="case-meta">
        {% if not node.field_role.isEmpty %}
          <div><dt class="case-meta__k">{{ i18n.rol }}</dt><dd class="case-meta__v">{{ node.field_role.value }}</dd></div>
        {% endif %}
        {% if not node.field_project_year.isEmpty %}
          <div><dt class="case-meta__k">{{ i18n.year }}</dt><dd class="case-meta__v">{{ node.field_project_year.value }}</dd></div>
        {% endif %}
        {% if not node.field_duration.isEmpty %}
          <div><dt class="case-meta__k">{{ i18n.duration }}</dt><dd class="case-meta__v">{{ node.field_duration.value }}</dd></div>
        {% endif %}
        {% if node.field_primary_technology.entity %}
          <div><dt class="case-meta__k">{{ i18n.stack }}</dt><dd class="case-meta__v">{{ node.field_primary_technology.entity.label }}</dd></div>
        {% endif %}
        {% if not node.field_external_url.isEmpty %}
          <div><dt class="case-meta__k">{{ i18n.live }}</dt><dd class="case-meta__v"><a class="case-meta__link" href="{{ node.field_external_url.uri }}" target="_blank" rel="noopener">{{ node.field_external_url.title|default(i18n.visit) }}</a></dd></div>
        {% endif %}
      </dl>
    </div>

    {% if _cover_url %}
      <figure class="case-head__cover">
        <img src="{{ _cover_url }}"
             alt="{{ _cover_alt }}"
             loading="eager"
             decoding="async">
      </figure>
    {% endif %}
  </header>

  {# §01 Desafío #}
  {% if not node.field_challenge_intro.isEmpty or not node.field_challenge_bullets.isEmpty %}
    <section class="case-section">
      <div class="case-section__num">{{ i18n.s1 }}</div>
      {% if not node.field_challenge_intro.isEmpty %}
        <p class="case-section__lede">{{ node.field_challenge_intro.value }}</p>
      {% endif %}
      {% if not node.field_challenge_bullets.isEmpty %}
        <ul class="case-bullets">
          {% for item in node.field_challenge_bullets %}
            <li>{{ item.value }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </section>
  {% endif %}

  {# §02 Enfoque (case_step paragraphs) #}
  {% if not node.field_approach_steps.isEmpty %}
    <section class="case-section">
      <div class="case-section__num">{{ i18n.s2 }}</div>
      <h2 class="case-section__title">{{ i18n.s2_title }}</h2>
      <div class="case-steps">
        {% for delta, item in node.field_approach_steps %}
          {%- set step = item.entity -%}
          {# Resolve the paragraph in the same language as the parent node
             — entity references load in the default language by default. #}
          {%- if step and step.hasTranslation(lang) -%}
            {%- set step = step.getTranslation(lang) -%}
          {%- endif -%}
          {% if step %}
            {% include 'byte:case-step-card' with {
              number: delta + 1,
              tag: step.field_step_tag.value,
              title: step.field_step_title.value,
              body: step.field_step_body.value,
            } only %}
          {% endif %}
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# §03 Resultados (metric paragraphs + embedded testimonial) #}
  {% if not node.field_results_metrics.isEmpty or not node.field_testimonial_embed.isEmpty %}
    <section class="case-section">
      <div class="case-section__num">{{ i18n.s3 }}</div>
      <h2 class="case-section__title">{{ i18n.s3_title }}</h2>

      {% if not node.field_results_metrics.isEmpty %}
        <div class="medidores">
          {% for item in node.field_results_metrics %}
            {%- set m = item.entity -%}
            {%- if m and m.hasTranslation(lang) -%}
              {%- set m = m.getTranslation(lang) -%}
            {%- endif -%}
            {% if m %}
              {% include 'byte:medidor' with {
                value: m.field_metric_value.value,
                key: m.field_metric_key.value,
                note: m.field_metric_note.value,
                variant: 'card',
              } only %}
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% if not node.field_testimonial_embed.isEmpty %}
        {%- set t = node.field_testimonial_embed.0.entity -%}
        {%- if t and t.hasTranslation(lang) -%}
          {%- set t = t.getTranslation(lang) -%}
        {%- endif -%}
        {% if t %}
          <div style="margin-top: 48px;">
            {% include 'byte:card-testimonio' with {
              quote: t.field_quote.value,
              name: t.field_author_name.value,
              role: t.field_author_role.value,
              initials: t.field_author_initials.value,
            } only %}
          </div>
        {% endif %}
      {% endif %}
    </section>
  {% endif %}

  {# §04 Aprendizaje #}
  {% if not node.field_lesson.isEmpty %}
    <section class="case-section">
      <div class="case-section__num">{{ i18n.s4 }}</div>
      <p class="case-section__body">{{ node.field_lesson.value }}</p>
    </section>
  {% endif %}
</article>

{# CTA final #}
{% if not node.field_cta_heading.isEmpty %}
  {% include 'byte:cta-final' with {
    title: node.field_cta_heading.value,
    sub: node.field_cta_sub.value,
    primary_label: i18n.cta_primary,
    primary_href: i18n.cta_primary_href,
    secondary_label: i18n.cta_secondary,
    secondary_href: '/' ~ lang ~ i18n.cta_secondary_path,
  } only %}
{% endif %}
