parameters:
    # Level 5 = full argument + return type checks + dead-code detection +
    # instanceof validation. We tried level 6 (missing typehints) but it
    # would require typing every Drupal render array (~45 violations) for
    # cosmetic gain only — not a useful tradeoff for a site this size.
    level: 5

    paths:
        - web/modules/custom
        - web/themes/custom

    excludePaths:
        analyseAndScan:
            - web/themes/custom/byte/node_modules/*
            - web/themes/custom/byte/dist/*
            # Tests use Drupal core base classes that pull a lot of legacy
            # surface; keep them out of analysis until the test suite is
            # established and we can lift level/strictness intentionally.
            - web/modules/custom/*/tests/*

    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
